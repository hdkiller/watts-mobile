{
  "hooks": {
    "after:bump": "node scripts/sync-expo-version.mjs && git add app.json"
  },
  "plugins": {
    "release-it-pnpm": {},
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "CHANGELOG.md"
    }
  },
  "npm": {
    "publish": false
  },
  "git": {
    "commitMessage": "chore: release ${version}",
    "tagName": "v${version}",
    "requireCleanWorkingDirectory": true
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  }
}
