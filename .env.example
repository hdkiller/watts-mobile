# Coach Watts Official Companion — copy to .env.
# Public client IDs (no secret). Must match the OAuthApp row on the instance you hit.

# --- Active (local coach-wattz IdP) — default for workspace development ---
EXPO_PUBLIC_DEFAULT_INSTANCE_URL=http://localhost:3099
EXPO_PUBLIC_OAUTH_CLIENT_ID=cc24aade-5a1a-42ec-af2c-7fe60923e3c2

# --- Production (https://coachwatts.com) — swap the two vars above when testing live ---
# EXPO_PUBLIC_DEFAULT_INSTANCE_URL=https://coachwatts.com
# EXPO_PUBLIC_OAUTH_CLIENT_ID=1c2dbf4d-51b8-4902-85e6-e4f2f48c70d9

# --- Maestro e2e auth seed (local / CI smoke only — never enable for store builds) ---
# Prefer coach-wattz e2e stack (:3199) + POST /api/__e2e/token — see docs/e2e.md
# EXPO_PUBLIC_E2E_AUTH=1
# EXPO_PUBLIC_E2E_INSTANCE_URL=http://localhost:3199
# EXPO_PUBLIC_E2E_ACCESS_TOKEN=
# EXPO_PUBLIC_E2E_REFRESH_TOKEN=
# EXPO_PUBLIC_OAUTH_CLIENT_ID=e2e00000-0000-4000-8000-000000000001
# EXPO_PUBLIC_E2E_ALLOWED_HOSTS=
# EXPO_PUBLIC_E2E_ALLOW_ANY_HOST=
# Ad-hoc against local IdP (:3099) is OK for device smoke; Maestro suite should use :3199.

# Optional — Android Google Maps (activity route map). Required for Android MapView;
# without it the native SDK crashes on attach. Restrict the key by package
# com.coachwatts.app + SHA-1. iOS uses Apple Maps (no key).
# Set both (or at least EXPO_PUBLIC_): JS guard needs EXPO_PUBLIC_; native manifest
# needs app.config → then `npx expo prebuild -p android` and rebuild.
GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional — Sentry (set via EAS secrets for store builds; do not commit real DSNs)
EXPO_PUBLIC_SENTRY_DSN=
# Optional release metadata (EAS may also inject EAS_BUILD_ID / EAS_BUILD_NUMBER via app.config.ts)
EXPO_PUBLIC_SENTRY_ENVIRONMENT=
EXPO_PUBLIC_SENTRY_RELEASE=
EXPO_PUBLIC_SENTRY_DIST=

# Native store subscriptions. Public SDK keys/product IDs are safe in the app bundle.
# RevenueCat secret API keys (REVENUECAT_API_V2_SECRET_KEY) are local tooling / MCP / server only —
# never ship them in the app bundle; production webhook secrets belong in coach-wattz.
EXPO_PUBLIC_NATIVE_SUBSCRIPTIONS_ENABLED=false
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_REVENUECAT_TEST_STORE_API_KEY=
# Comma-separated store product IDs (Apple ASC IDs + Google `productId:basePlanId`)
EXPO_PUBLIC_SUBSCRIPTION_SUPPORTER_PRODUCT_IDS=
EXPO_PUBLIC_SUBSCRIPTION_PRO_PRODUCT_IDS=

# Local RevenueCat REST API v2 + MCP (gitignored .env only)
REVENUECAT_PROJECT_ID=
REVENUECAT_API_V2_SECRET_KEY=
