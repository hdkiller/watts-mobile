# Coach Watts Official Companion — copy to .env.
# Public client IDs (no secret). Must match the OAuthApp row on the instance you hit.

# --- Active (local coach-wattz IdP) — default for workspace development ---
EXPO_PUBLIC_DEFAULT_INSTANCE_URL=http://localhost:3099
EXPO_PUBLIC_OAUTH_CLIENT_ID=cc24aade-5a1a-42ec-af2c-7fe60923e3c2

# --- Production (https://coachwatts.com) — swap the two vars above when testing live ---
# EXPO_PUBLIC_DEFAULT_INSTANCE_URL=https://coachwatts.com
# EXPO_PUBLIC_OAUTH_CLIENT_ID=1c2dbf4d-51b8-4902-85e6-e4f2f48c70d9

# Optional — Sentry (set via EAS secrets for store builds; do not commit real DSNs)
EXPO_PUBLIC_SENTRY_DSN=
# Optional release metadata (EAS may also inject EAS_BUILD_ID / EAS_BUILD_NUMBER via app.config.ts)
EXPO_PUBLIC_SENTRY_ENVIRONMENT=
EXPO_PUBLIC_SENTRY_RELEASE=
EXPO_PUBLIC_SENTRY_DIST=
