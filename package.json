{
  "name": "watts-mobile",
  "main": "expo-router/entry",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "SENTRY_DISABLE_AUTO_UPLOAD=true expo run:android",
    "ios": "SENTRY_DISABLE_AUTO_UPLOAD=true expo run:ios",
    "ios:free-team:prebuild": "IOS_FREE_TEAM=1 expo prebuild --platform ios --clean",
    "ios:free-team:device": "IOS_FREE_TEAM=1 SENTRY_DISABLE_AUTO_UPLOAD=true expo run:ios --device",
    "ios:free-team:device:release": "IOS_FREE_TEAM=1 SENTRY_DISABLE_AUTO_UPLOAD=true expo run:ios --device --configuration Release",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "maestro test maestro",
    "test:e2e:unauth": "maestro test maestro/smoke-unauth.yaml",
    "test:e2e:shell": "maestro test maestro/smoke-shell.yaml",
    "lint": "expo lint && node scripts/check-theme-tokens.mjs",
    "lint:theme": "node scripts/check-theme-tokens.mjs",
    "release": "release-it",
    "release:patch": "release-it patch",
    "release:minor": "release-it minor",
    "release:major": "release-it major",
    "release:android:github": "node scripts/publish-android-github-release.mjs",
    "release:android:github:local": "node scripts/publish-android-github-release.mjs --local"
  },
  "dependencies": {
    "@ai-sdk/react": "^4.0.18",
    "@expo/ui": "~57.0.7",
    "@kingstinct/react-native-healthkit": "^14.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@sentry/react-native": "^7.11.0",
    "@tanstack/query-async-storage-persister": "^5.101.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-persist-client": "^5.101.2",
    "ai": "^7.0.18",
    "expo": "~57.0.7",
    "expo-audio": "~57.0.3",
    "expo-auth-session": "~57.0.4",
    "expo-background-task": "~57.0.5",
    "expo-build-properties": "~57.0.6",
    "expo-constants": "~57.0.6",
    "expo-crypto": "~57.0.1",
    "expo-dev-client": "~57.0.7",
    "expo-device": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-image-picker": "~57.0.5",
    "expo-linking": "~57.0.3",
    "expo-notifications": "~57.0.6",
    "expo-quick-actions": "^6.0.2",
    "expo-router": "~57.0.7",
    "expo-secure-store": "~57.0.1",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-symbols": "~57.0.1",
    "expo-task-manager": "~57.0.5",
    "expo-web-browser": "~57.0.1",
    "expo-widgets": "~57.0.6",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-css-interop": "^0.2.6",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-health-connect": "^3.5.3",
    "react-native-maps": "1.27.2",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-purchases": "^10.4.4",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "tailwindcss": "3.4.17"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "^7.29.7",
    "@release-it/conventional-changelog": "^10.0.4",
    "@sentry/cli": "2.58.4",
    "@types/react": "~19.2.17",
    "babel-preset-expo": "~57.0.3",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~57.0.0",
    "release-it": "^19.2.2",
    "release-it-pnpm": "^4.6.6",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  }
}
