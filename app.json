{
  "expo": {
    "name": "Coach Watts",
    "slug": "coach-watts-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "coachwatts",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.coachwatts.mobile",
      "icon": "./assets/images/icon.png",
      "associatedDomains": [
        "applinks:coachwatts.com"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Coach Watts uses the camera so you can photograph meals and share them in Coach chat for nutrition logging.",
        "NSPhotoLibraryUsageDescription": "Coach Watts accesses your photo library so you can attach meal photos in Coach chat for nutrition logging."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#09090b",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.coachwatts.mobile",
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "https",
              "host": "coachwatts.com",
              "pathPrefix": "/go"
            }
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@sentry/react-native",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#e11d48",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Coach Watts accesses your photo library so you can attach meal photos in Coach chat for nutrition logging.",
          "cameraPermission": "Coach Watts uses the camera so you can photograph meals and share them in Coach chat for nutrition logging."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#09090b",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#09090b"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "defaultInstanceUrl": "https://coachwatts.com",
      "oauthClientId": "1c2dbf4d-51b8-4902-85e6-e4f2f48c70d9",
      "sentryDsn": "",
      "router": {},
      "eas": {
        "projectId": "3fad7b8c-dc45-4616-8d77-d48f44d161b2"
      }
    },
    "owner": "hdkillers-team"
  }
}
