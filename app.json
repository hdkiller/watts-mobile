{
  "expo": {
    "name": "Coach Watts",
    "slug": "coach-watts-app",
    "version": "0.1.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "coachwatts",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.coachwatts.mobile",
      "icon": "./assets/images/icon.png",
      "associatedDomains": [
        "applinks:coachwatts.com"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Coach Watts uses the camera so you can photograph meals and share them in Coach chat for nutrition logging.",
        "NSPhotoLibraryUsageDescription": "Coach Watts accesses your photo library so you can attach meal photos in Coach chat for nutrition logging.",
        "NSHealthShareUsageDescription": "Coach Watts reads sleep, heart rate (incl. workout heart-rate and power/cadence/speed streams), HRV, body metrics, steps, distance, exercise minutes, floors, GPS workout routes, and workouts from Apple Health to prefill check-ins and, when you enable Health Sync, upload them to your Coach Watts instance.",
        "NSHealthUpdateUsageDescription": "Coach Watts does not write health data to Apple Health."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": [],
        "com.apple.developer.healthkit.background-delivery": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#09090b",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.coachwatts.mobile",
      "permissions": [
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_WEIGHT",
        "android.permission.health.READ_RESTING_HEART_RATE",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_HEART_RATE_VARIABILITY",
        "android.permission.health.READ_BODY_FAT",
        "android.permission.health.READ_OXYGEN_SATURATION",
        "android.permission.health.READ_RESPIRATORY_RATE",
        "android.permission.health.READ_VO2_MAX",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_DISTANCE",
        "android.permission.health.READ_FLOORS_CLIMBED",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_TOTAL_CALORIES_BURNED",
        "android.permission.health.READ_BASAL_METABOLIC_RATE",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.READ_EXERCISE_ROUTES",
        "android.permission.health.READ_POWER",
        "android.permission.health.READ_SPEED",
        "android.permission.health.READ_CYCLING_PEDALING_CADENCE",
        "android.permission.health.READ_STEPS_CADENCE",
        "android.permission.health.READ_HEALTH_DATA_IN_BACKGROUND"
      ],
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "https",
              "host": "coachwatts.com",
              "pathPrefix": "/go"
            }
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "@sentry/react-native/expo",
        {
          "organization": "watt-mind",
          "project": "coach-watts-app",
          "url": "https://de.sentry.io/"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#00DC82",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Coach Watts accesses your photo library so you can attach meal photos in Coach chat for nutrition logging.",
          "cameraPermission": "Coach Watts uses the camera so you can photograph meals and share them in Coach chat for nutrition logging."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#fafafa",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#09090b"
          }
        }
      ],
      [
        "expo-widgets",
        {
          "bundleIdentifier": "com.coachwatts.mobile.widgets",
          "groupIdentifier": "group.com.coachwatts.mobile",
          "widgets": [
            {
              "name": "TodaySessionWidget",
              "displayName": "Today’s session",
              "description": "Today’s Coach Watts recommendation and planned session.",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            }
          ]
        }
      ],
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "Coach Watts reads sleep, heart rate (incl. workout heart-rate and power/cadence/speed streams), HRV, body metrics, steps, distance, exercise minutes, floors, GPS workout routes, and workouts from Apple Health to prefill check-ins and, when you enable Health Sync, upload them to your Coach Watts instance.",
          "NSHealthUpdateUsageDescription": "Coach Watts does not write health data to Apple Health.",
          "background": true
        }
      ],
      "react-native-health-connect",
      "./plugins/withHealthConnectPermissionDelegate",
      "expo-background-task",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "defaultInstanceUrl": "https://coachwatts.com",
      "oauthClientId": "1c2dbf4d-51b8-4902-85e6-e4f2f48c70d9",
      "sentryDsn": "",
      "router": {},
      "eas": {
        "projectId": "3fad7b8c-dc45-4616-8d77-d48f44d161b2"
      }
    },
    "owner": "hdkillers-team"
  }
}
