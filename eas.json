{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_SENTRY_ENVIRONMENT": "development"
      }
    },
    "e2e": {
      "extends": "development",
      "env": {
        "EXPO_PUBLIC_SENTRY_ENVIRONMENT": "e2e",
        "EXPO_PUBLIC_E2E_AUTH": "1",
        "EXPO_PUBLIC_E2E_INSTANCE_URL": "http://localhost:3099"
      }
    },
    "preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_SENTRY_ENVIRONMENT": "preview"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_SENTRY_ENVIRONMENT": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
